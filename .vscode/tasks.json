{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Mobile Dev Server",
            "type": "shell",
            "command": "pnpm --filter mobile dev",
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "VITE",
                    "endsPattern": "Local:"
                }
            },
            "presentation": {
                "group": "devServers",
                "reveal": "always"
            }
        }
    ]
}
