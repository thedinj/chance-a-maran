{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Backend — Next.js",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/apps/backend",
            "runtimeExecutable": "pnpm",
            "runtimeArgs": ["dev"],
            "env": {
                "NODE_OPTIONS": "--inspect"
            },
            "skipFiles": ["<node_internals>/**", "${workspaceFolder}/**/node_modules/**"],
            "serverReadyAction": {
                "pattern": "started server on .+, url: (https?://.+)",
                "uriFormat": "%s",
                "action": "openExternally"
            }
        },
        {
            "name": "Mobile — Chrome",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8100",
            "webRoot": "${workspaceFolder}/apps/mobile/src",
            "preLaunchTask": "Start Mobile Dev Server"
        }
    ],
    "compounds": [
        {
            "name": "All Apps",
            "configurations": ["Backend — Next.js", "Mobile — Chrome"],
            "stopAll": true
        }
    ]
}
