{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "[server] Backend",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/apps/backend",
            "runtimeExecutable": "pnpm",
            "runtimeArgs": ["dev"],
            "env": {
                "NODE_OPTIONS": "--inspect"
            },
            "skipFiles": ["<node_internals>/**", "${workspaceFolder}/**/node_modules/**"]
        },
        {
            "name": "[browser] Admin (localhost:3000)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:3000/admin",
            "webRoot": "${workspaceFolder}/apps/backend/src"
        },
        {
            "name": "[browser] Mobile (localhost:8100)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8100",
            "webRoot": "${workspaceFolder}/apps/mobile/src",
            "preLaunchTask": "Start Mobile Dev Server"
        }
    ],
    "compounds": [
        {
            "name": "Backend",
            "configurations": ["[server] Backend", "[browser] Admin (localhost:3000)"],
            "stopAll": true
        },
        {
            "name": "Mobile",
            "configurations": ["[server] Backend", "[browser] Mobile (localhost:8100)"],
            "stopAll": true
        }
    ]
}
