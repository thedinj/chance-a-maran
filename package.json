{
    "name": "chance-a-maran",
    "private": true,
    "scripts": {
        "preinstall": "only-allow pnpm",
        "dev": "turbo dev",
        "build": "turbo build",
        "build:core": "pnpm --filter @chance/core build",
        "db:seed": "pnpm --filter backend db:seed",
        "test": "turbo test",
        "lint": "turbo lint",
        "typecheck": "turbo typecheck",
        "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .prettierignore"
    },
    "packageManager": "pnpm@10.33.0",
    "pnpm": {
        "overrides": {
        },
        "onlyBuiltDependencies": [
            "better-sqlite3",
            "esbuild",
            "sharp"
        ]
    },
    "devDependencies": {
        "only-allow": "^1.2.1",
        "prettier": "^3.8.1",
        "turbo": "^2.8.20",
        "typescript": "^6.0.2"
    }
}
