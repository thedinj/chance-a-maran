# JWT Configuration
JWT_SECRET="your-secret-key-change-this-in-production"
JWT_ISSUER="chanced-a-maran"
JWT_AUDIENCE="chanced-a-maran-api"
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# Admin Bootstrap User
ADMIN_EMAIL="admin@chanced-a-maran.local"
ADMIN_NAME="Admin"
ADMIN_PASSWORD="change-this-password"

# Optional: Second Test User (for testing collaboration features)
#SECOND_USER_EMAIL="user@chanced-a-maran.local"
#SECOND_USER_NAME="Test User"
#SECOND_USER_PASSWORD="change-this-password"

# Registration Restriction (optional)
# Used during initial database seeding to set the invitation code requirement.
# After seeding, the value is stored in the AppSetting table and can be changed via admin UI (future feature).
# Leave empty or unset to allow open registration.
REGISTRATION_INVITATION_CODE=""

# Server
NODE_ENV="development"
PORT=3000
